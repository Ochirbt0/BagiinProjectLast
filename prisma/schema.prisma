generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String         @id @default(cuid())
  name            String
  avatarUrl       String?
  score           Int            @default(0)
  createdAt       DateTime       @default(now())
  

  unlockedHeroes  UnlockedHero[]
}

model Hero {
  id            Int            @id @default(autoincrement())
  name          String
  image         String
  requiredStars Int            @default(0) 
  

  unlockedBy    UnlockedHero[]
}


model UnlockedHero {
  userId    String
  heroId    Int
  user      User     @relation(fields: [userId], references: [id])
  hero      Hero     @relation(fields: [heroId], references: [id])
  unlockedAt DateTime @default(now())

  @@id([userId, heroId])
}

model UserProgress {
  id        String   @id @default(cuid())
  userId    String
  grade     Int      
  level     String   
  topicId   Int      
  completed Boolean  @default(false)

  @@unique([userId, grade, level, topicId])
}